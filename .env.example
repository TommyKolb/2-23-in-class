# Copy to .env and fill in your values
# DO NOT commit .env to version control

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/ai_tinder"

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="change_me_access_secret_min_32_chars"
JWT_REFRESH_SECRET="change_me_refresh_secret_min_32_chars"

# Token lifetimes
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_DAYS=30

# Server
PORT=3001
NODE_ENV=development

# CORS — comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:5500,http://127.0.0.1:5500"

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
SWIPE_RATE_LIMIT_WINDOW_MS=3600000
SWIPE_RATE_LIMIT_MAX=200
